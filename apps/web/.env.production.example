# Copy these into Vercel's project "Environment Variables" settings — not into a file. This
# file just documents what's needed and where each value comes from.

# Your Railway deployment's public URL (the backend). Same value for both — one is the REST
# API base, the other is the Socket.IO connection target.
NEXT_PUBLIC_API_URL="https://your-app.up.railway.app"
NEXT_PUBLIC_SOCKET_URL="https://your-app.up.railway.app"
