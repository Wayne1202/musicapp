DATABASE_URL="postgresql://musicapp:musicapp@localhost:5432/musicapp?schema=public"
# Only matters when DATABASE_URL is a pooled connection (e.g. Neon in production — see
# .env.production.example). For a plain local Postgres like this one, just mirror DATABASE_URL.
DIRECT_URL="postgresql://musicapp:musicapp@localhost:5432/musicapp?schema=public"
PORT=4000
CLIENT_ORIGIN="http://localhost:3000"

# Recommended — required for in-app song search specifically (there's no keyless search API to
# fall back to); without it the search box just tells users to paste a link instead, and the
# rest of the app is unaffected. Also enables real video titles/thumbnails/durations when adding
# by URL, and the "play music when queue is empty" autoplay-fallback setting (both silently
# degrade — oEmbed metadata / staying idle — if this is unset, same as before). See README.md
# for how to get a key.
YOUTUBE_API_KEY=
