DATABASE_URL="postgresql://musicapp:musicapp@localhost:5432/musicapp?schema=public"
# Only matters when DATABASE_URL is a pooled connection (e.g. Neon in production — see
# .env.production.example). For a plain local Postgres like this one, just mirror DATABASE_URL.
DIRECT_URL="postgresql://musicapp:musicapp@localhost:5432/musicapp?schema=public"
PORT=4000
CLIENT_ORIGIN="http://localhost:3000"

# Optional: enables real video titles/thumbnails/durations via the YouTube Data API, and the
# "play music when queue is empty" autoplay-fallback feature (rooms with that setting on just
# stay idle instead if this is unset). Without it, added songs fall back to YouTube's public
# oEmbed endpoint (title + thumbnail, no duration).
YOUTUBE_API_KEY=
