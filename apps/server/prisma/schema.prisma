generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Room {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  repeatQueue Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sessions       UserSession[]
  queueItems     QueueItem[]
  playbackState  PlaybackState?
  recentlyPlayed RecentlyPlayedItem[]
  chatMessages   ChatMessage[]

  @@index([code])
}

model UserSession {
  id          String   @id @default(cuid())
  displayName String
  roomId      String
  isOnline    Boolean  @default(true)
  lastSeenAt  DateTime @default(now())
  createdAt   DateTime @default(now())

  room         Room          @relation(fields: [roomId], references: [id], onDelete: Cascade)
  queueItems   QueueItem[]
  chatMessages ChatMessage[]

  @@index([roomId])
  @@index([roomId, isOnline])
}

model QueueItem {
  id        String   @id @default(cuid())
  roomId    String
  videoId   String
  title     String
  thumbnail String
  duration  Int
  position  Int
  addedById String
  createdAt DateTime @default(now())

  room    Room        @relation(fields: [roomId], references: [id], onDelete: Cascade)
  addedBy UserSession @relation(fields: [addedById], references: [id], onDelete: Cascade)

  @@index([roomId, position])
  @@index([roomId, videoId])
}

model PlaybackState {
  id                 String   @id @default(cuid())
  roomId             String   @unique
  currentVideoId     String?
  currentTitle       String?
  currentThumbnail   String?
  currentDuration    Int      @default(0)
  currentTimestamp   Float    @default(0)
  isPlaying          Boolean  @default(false)
  // Denormalized snapshot of who queued the currently playing song — same rationale as
  // QueueItem's own snapshotted title/thumbnail/duration below, rather than a live join.
  currentAddedById   String?
  currentAddedByName String?
  updatedAt          DateTime @updatedAt

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId])
}

model RecentlyPlayedItem {
  id          String   @id @default(cuid())
  roomId      String
  videoId     String
  title       String
  thumbnail   String
  duration    Int
  addedByName String?
  playedAt    DateTime @default(now())

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId, playedAt])
}

model ChatMessage {
  id          String   @id @default(cuid())
  roomId      String
  sessionId   String
  displayName String
  content     String
  createdAt   DateTime @default(now())

  room    Room        @relation(fields: [roomId], references: [id], onDelete: Cascade)
  session UserSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([roomId, createdAt])
}
