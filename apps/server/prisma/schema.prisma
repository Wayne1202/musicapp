generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // DATABASE_URL is Neon's pooled (PgBouncer) connection string, used for normal app queries.
  // Migrations need DIRECT_URL (Neon's non-pooled connection string) instead: Prisma's migration
  // engine takes an advisory lock that PgBouncer's transaction-pooling mode doesn't support
  // reliably, which can make `prisma migrate deploy` silently no-op through the pooler even
  // though it reports success. Falls back to DATABASE_URL if DIRECT_URL isn't set (e.g. local
  // dev against a plain, unpooled Postgres, where there's no distinction to make).
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum RoomStatus {
  ACTIVE
  ENDED
}

enum QueueAddPermission {
  ANYONE
  HOST_ONLY
}

enum SkipMode {
  ANYONE
  HOST_ONLY
  VOTE
}

model Room {
  id          String     @id @default(cuid())
  code        String     @unique
  name        String
  repeatQueue Boolean    @default(false)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  status             RoomStatus         @default(ACTIVE)
  hostSessionId      String?
  queueAddPermission QueueAddPermission @default(ANYONE)
  skipMode           SkipMode           @default(ANYONE)
  autoShuffle        Boolean            @default(false)
  chatEnabled        Boolean            @default(true)
  reactionsEnabled   Boolean            @default(true)
  allowGuestReorder  Boolean            @default(true)
  queueLocked        Boolean            @default(false)

  sessions       UserSession[]
  queueItems     QueueItem[]
  playbackState  PlaybackState?
  recentlyPlayed RecentlyPlayedItem[]
  chatMessages   ChatMessage[]
  events         RoomEvent[]

  @@index([code])
}

model UserSession {
  id          String   @id @default(cuid())
  displayName String
  roomId      String
  isOnline    Boolean  @default(true)
  lastSeenAt  DateTime @default(now())
  createdAt   DateTime @default(now())

  room         Room          @relation(fields: [roomId], references: [id], onDelete: Cascade)
  queueItems   QueueItem[]
  chatMessages ChatMessage[]

  @@index([roomId])
  @@index([roomId, isOnline])
}

model QueueItem {
  id        String   @id @default(cuid())
  roomId    String
  videoId   String
  title     String
  thumbnail String
  duration  Int
  position  Int
  addedById String
  createdAt DateTime @default(now())

  room    Room        @relation(fields: [roomId], references: [id], onDelete: Cascade)
  addedBy UserSession @relation(fields: [addedById], references: [id], onDelete: Cascade)

  @@index([roomId, position])
  @@index([roomId, videoId])
}

model PlaybackState {
  id                 String   @id @default(cuid())
  roomId             String   @unique
  currentVideoId     String?
  currentTitle       String?
  currentThumbnail   String?
  currentDuration    Int      @default(0)
  currentTimestamp   Float    @default(0)
  isPlaying          Boolean  @default(false)
  // Denormalized snapshot of who queued the currently playing song — same rationale as
  // QueueItem's own snapshotted title/thumbnail/duration below, rather than a live join.
  currentAddedById   String?
  currentAddedByName String?
  updatedAt          DateTime @updatedAt

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId])
}

model RecentlyPlayedItem {
  id          String   @id @default(cuid())
  roomId      String
  videoId     String
  title       String
  thumbnail   String
  duration    Int
  addedByName String?
  playedAt    DateTime @default(now())

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId, playedAt])
}

enum ChatMessageType {
  USER
  SYSTEM
}

model ChatMessage {
  id          String          @id @default(cuid())
  roomId      String
  sessionId   String?
  displayName String
  content     String
  type        ChatMessageType @default(USER)
  createdAt   DateTime        @default(now())

  room    Room         @relation(fields: [roomId], references: [id], onDelete: Cascade)
  session UserSession? @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([roomId, createdAt])
}

enum RoomEventType {
  JOINED
  LEFT
  HOST_TRANSFERRED
  QUEUE_LOCKED
  QUEUE_UNLOCKED
  VOTE_SKIP_PASSED
  ROOM_ENDED
}

model RoomEvent {
  id         String        @id @default(cuid())
  roomId     String
  type       RoomEventType
  actorName  String?
  targetName String?
  createdAt  DateTime      @default(now())

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId, createdAt])
}
