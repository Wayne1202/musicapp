# Copy these into Railway's service "Variables" tab — not into a file. This file just
# documents what's needed and where each value comes from.

# From Neon: project dashboard -> Connection string (use the "pooled" connection string —
# the one with "-pooler" in the host). Used for the app's normal runtime queries.
DATABASE_URL="postgresql://<user>:<password>@<neon-host>-pooler/<db>?sslmode=require"

# From the same Neon dashboard -> Connection string, but this time the "direct" connection
# (no "-pooler" in the host). REQUIRED, separate from DATABASE_URL above: the Dockerfile runs
# `prisma migrate deploy` on every boot, and Prisma's migration engine needs a direct connection
# — pooled connections (PgBouncer) don't support the advisory lock it takes, which can make
# `migrate deploy` silently no-op (reports success, schema doesn't actually change) instead of
# erroring loudly. If migrations ever seem to "not take" after a deploy, check this first.
DIRECT_URL="postgresql://<user>:<password>@<neon-host>/<db>?sslmode=require"

# Railway sets PORT itself; only needed if running this Dockerfile somewhere else.
PORT=4000

# Your Vercel deployment's URL (the web app), so the backend accepts requests/websocket
# connections from it. Comma-separate multiple origins, e.g. production + a preview URL.
CLIENT_ORIGIN="https://your-app.vercel.app"

# Optional: enables real video titles/thumbnails/durations via the YouTube Data API, and the
# "play music when queue is empty" autoplay-fallback feature. Without it, the server falls back
# to YouTube's public oEmbed endpoint for metadata, and autoplay-fallback rooms just stay idle.
YOUTUBE_API_KEY=
