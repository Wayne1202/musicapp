# Copy these into Railway's service "Variables" tab — not into a file. This file just
# documents what's needed and where each value comes from.

# From Neon: project dashboard -> Connection string (use the "pooled" connection string).
DATABASE_URL="postgresql://<user>:<password>@<neon-host>/<db>?sslmode=require"

# Railway sets PORT itself; only needed if running this Dockerfile somewhere else.
PORT=4000

# Your Vercel deployment's URL (the web app), so the backend accepts requests/websocket
# connections from it. Comma-separate multiple origins, e.g. production + a preview URL.
CLIENT_ORIGIN="https://your-app.vercel.app"

# Optional: enables real video titles/thumbnails/durations via the YouTube Data API.
# Without it, the server falls back to YouTube's public oEmbed endpoint.
YOUTUBE_API_KEY=
